<script>
var dirty=false;
function mark(){dirty=true;document.getElementById('save-status').textContent='Alterações não salvas'}
document.addEventListener('input',mark);

function showBU(id,btn){
  document.querySelectorAll('.bu-section').forEach(function(s){s.classList.remove('visible')});
  document.querySelectorAll('.tab-btn').forEach(function(b){b.classList.remove('active')});
  document.getElementById('bu-'+id).classList.add('visible');
  btn.classList.add('active');
}

function addTask(cid,nid){
  var c=document.getElementById(cid),ab=c.querySelector('.add-task-btn');
  var d=document.createElement('div');d.className='task-card priority-low';
  d.innerHTML='<div class="task-actions">'+(nid?'<button class="task-btn" onclick="moveCard(this,\''+nid+'\')">→</button>':'')+'<button class="task-btn" onclick="rmCard(this)">×</button></div><div class="task-title" contenteditable="true">Nova tarefa</div><div class="task-meta"><span class="task-date" contenteditable="true">Data</span><span class="task-owner" contenteditable="true">@Responsável</span></div>';
  c.insertBefore(d,ab);d.querySelector('.task-title').focus();mark();
}
function rmCard(btn){if(confirm('Remover esta tarefa?')){btn.closest('.task-card').remove();mark()}}
function moveCard(btn,tid){
  var card=btn.closest('.task-card'),t=document.getElementById(tid);
  if(!t)return;btn.remove();t.insertBefore(card,t.querySelector('.add-task-btn'));mark();
}

function addKPI(barId){
  var bar=document.getElementById(barId);
  var c=document.createElement('div');c.className='kpi-card';
  c.innerHTML='<div class="kpi-label" contenteditable="true">Indicador</div><div class="kpi-value" contenteditable="true">—</div><div class="kpi-sub" contenteditable="true">Descrição</div><button class="kpi-rm" onclick="this.closest(\'.kpi-card\').remove();mark()">✕ remover</button>';
  bar.appendChild(c);mark();
}

function addPill(btn){
  var colors=['navy','mustard','green','red'];
  var p=document.createElement('button');
  p.className='rm-pill '+colors[Math.floor(Math.random()*4)];
  p.contentEditable='true';p.textContent='Nova entrega';
  btn.parentNode.insertBefore(p,btn);p.focus();mark();
}

function addFTask(colId){
  var col=document.getElementById(colId)||document.querySelector('.ferraz-cols>div:first-child');
  var addBtn=col?col.querySelector('.add-f-btn'):null;
  var d=document.createElement('div');d.className='f-task';
  d.innerHTML='<div class="task-actions"><button class="task-btn" onclick="rmFTask(this)">×</button></div><div class="f-task-title" contenteditable="true">Nova tarefa</div><div class="f-task-meta"><span class="f-badge f-date" contenteditable="true">Data</span></div>';
  if(addBtn){col.insertBefore(d,addBtn);}else{d.querySelector('.f-task-title').focus();}
  d.querySelector('.f-task-title').focus();mark();
}
function rmFTask(btn){if(confirm('Remover?')){btn.closest('.f-task').remove();mark()}}

function addPA(bu){
  var pid='pa-'+bu+'-pending';
  var c=document.getElementById(pid);
  if(!c)return;
  var em=c.querySelector('.pa-empty');if(em)em.remove();
  var row=document.createElement('div');row.className='pa-row';row.dataset.bu=bu;
  row.innerHTML='<div class="pa-row-actions"><button class="task-btn" title="Mover" onclick="togglePA(this)">⇄</button><button class="task-btn" onclick="rmPA(this)">×</button></div><div class="pa-row-desc" contenteditable="true">Descreva o compromisso assumido</div><div class="pa-row-meta"><div class="pa-meta-field"><span class="pa-meta-label">Responsável</span><span class="pa-meta-val" contenteditable="true">@Responsável</span></div><div class="pa-meta-field"><span class="pa-meta-label">Prazo</span><span class="pa-meta-val" contenteditable="true">dd/mm</span></div><div class="pa-meta-field"><span class="pa-meta-label">Status</span><select class="pa-status-sel s-pending" onchange="onSelChange(this)"><option value="pending" selected>⏳ Pendente</option><option value="done">✅ Concluído</option></select></div></div>';
  c.appendChild(row);row.querySelector('.pa-row-desc').focus();refreshCounts(bu);mark();
}

function onSelChange(sel){
  var row=sel.closest('.pa-row');
  var bu=getBU(row);
  var isDone=sel.value==='done';
  var targetId='pa-'+bu+'-'+(isDone?'done':'pending');
  var t=document.getElementById(targetId);
  var em=t?t.querySelector('.pa-empty'):null;if(em)em.remove();
  sel.className='pa-status-sel '+(isDone?'s-done':'s-pending');
  row.classList.toggle('done-row',isDone);
  if(t)t.appendChild(row);
  refreshCounts(bu);mark();
}

function togglePA(btn){
  var sel=btn.closest('.pa-row').querySelector('.pa-status-sel');
  sel.value=sel.value==='pending'?'done':'pending';onSelChange(sel);
}

function rmPA(btn){
  if(confirm('Remover esta pendência?')){var row=btn.closest('.pa-row');var bu=getBU(row);row.remove();refreshCounts(bu);mark();}
}

function getBU(row){
  var s=row.closest('.bu-section');return s?s.id.replace('bu-',''):'';
}

function refreshCounts(bu){
  ['pending','done'].forEach(function(s){
    var body=document.getElementById('pa-'+bu+'-'+s);
    if(!body)return;
    var n=body.querySelectorAll('.pa-row').length;
    var cntEl=document.getElementById('cnt-'+bu+'-'+s);
    if(cntEl)cntEl.textContent=n;
    if(n===0&&!body.querySelector('.pa-empty')){
      var e=document.createElement('div');e.className='pa-empty';
      e.textContent=s==='pending'?'Nenhuma pendência registrada':'Nenhum item concluído ainda';
      body.appendChild(e);
    }
  });
}

function saveHTML(){
  var html='<!DOCTYPE html>\n'+document.documentElement.outerHTML;
  var blob=new Blob([html],{type:'text/html;charset=utf-8'});
  var a=document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download='dashboard_pdca_marketing_'+new Date().toISOString().slice(0,10)+'.html';
  a.click();URL.revokeObjectURL(a.href);
  dirty=false;
  document.getElementById('save-status').textContent='Salvo às '+new Date().toLocaleTimeString('pt-BR');
}
window.addEventListener('beforeunload',function(e){if(dirty){e.preventDefault();e.returnValue=''}});
</script>
