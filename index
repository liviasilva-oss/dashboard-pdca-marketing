<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard PDCA — Liderança de Marketing</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#0D2140;--navy-l:#1a3a5c;--mustard:#C8922A;--mustard-l:#F0B84A;
  --mustard-bg:#FDF3DC;--gray-light:#E5E7EB;--gray-bg:#F3F4F6;
  --white:#FFFFFF;--text-dark:#111827;--text-muted:#6B7280;--border:rgba(0,0,0,0.09);
}
body{font-family:'Segoe UI',system-ui,-apple-system,sans-serif;background:#EEF0F4;color:var(--text-dark);min-height:100vh}
.top-bar{background:var(--navy);padding:16px 28px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:200;box-shadow:0 2px 14px rgba(0,0,0,0.22)}
.top-bar h1{color:#fff;font-size:16px;font-weight:700;letter-spacing:-.3px;outline:none;min-width:1px}
.top-bar p{color:rgba(255,255,255,.5);font-size:11px;margin-top:2px;outline:none;min-width:1px}
.top-bar-right{display:flex;gap:8px;align-items:center;flex-shrink:0}
.badge{background:rgba(255,255,255,.1);color:var(--mustard-l);font-size:11px;font-weight:700;padding:5px 13px;border-radius:20px;border:1px solid rgba(200,146,42,.35);outline:none;min-width:1px;cursor:text}
.main{max-width:1440px;margin:0 auto;padding:20px 20px 60px}
.export-bar{display:flex;gap:8px;margin-bottom:16px;align-items:center;flex-wrap:wrap}
.btn-exp{padding:8px 16px;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;transition:all .15s;border:1.5px solid var(--navy);color:var(--navy);background:var(--white)}
.btn-exp:hover{background:var(--navy);color:#fff}
.btn-exp.primary{background:var(--navy);color:#fff}
.btn-exp.primary:hover{background:var(--navy-l)}
#save-status{font-size:11px;color:var(--text-muted);margin-left:auto}
.tabs{display:flex;gap:4px;background:var(--white);padding:5px;border-radius:12px;border:.5px solid var(--border);margin-bottom:20px;overflow-x:auto;box-shadow:0 1px 4px rgba(0,0,0,.05)}
.tab-btn{flex:1;min-width:120px;padding:10px 14px;border:none;background:none;cursor:pointer;border-radius:8px;font-size:13px;font-weight:600;color:var(--text-muted);transition:all .15s;white-space:nowrap;font-family:inherit}
.tab-btn.active{background:var(--navy);color:#fff}
.tab-btn.ferraz-tab.active{background:#7C3AED}
.tab-btn.ferraz-tab:not(.active){color:#7C3AED}
.tab-btn:hover:not(.active){background:var(--gray-bg);color:var(--text-dark)}
.bu-section{display:none}
.bu-section.visible{display:block}
.section-header{background:var(--navy);border-radius:11px;padding:15px 20px;margin-bottom:16px;display:flex;align-items:center;justify-content:space-between;gap:12px}
.section-header h2{color:#fff;font-size:15px;font-weight:700;outline:none;min-width:1px}
.sec-sub{color:var(--mustard-l);font-size:12px;outline:none;min-width:1px;white-space:nowrap}
.section-header.ferraz-header{background:linear-gradient(135deg,#4C1D95,#7C3AED)}

/* KPI */
.kpi-bar{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-bottom:6px}
.kpi-card{background:var(--white);border:.5px solid var(--border);border-radius:10px;padding:13px 15px;border-top:3px solid var(--navy);box-shadow:0 1px 3px rgba(0,0,0,.04)}
.kpi-card.warn{border-top-color:var(--mustard)}.kpi-card.danger{border-top-color:#EF4444}.kpi-card.ok{border-top-color:#10B981}
.kpi-label{font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;font-weight:700;margin-bottom:4px;outline:none;min-width:1px}
.kpi-value{font-size:21px;font-weight:800;color:var(--text-dark);line-height:1;outline:none;min-width:1px}
.kpi-sub{font-size:10px;color:var(--text-muted);margin-top:3px;outline:none;min-width:1px}
.kpi-rm{border:none;background:none;cursor:pointer;font-size:10px;color:#EF4444;font-family:inherit;margin-top:5px;display:block}
.kpi-actions-bar{text-align:right;margin-bottom:14px}
.kpi-add-btn{padding:5px 12px;border:1.5px dashed var(--gray-light);background:none;border-radius:7px;font-size:11px;color:var(--text-muted);cursor:pointer;font-family:inherit}
.kpi-add-btn:hover{border-color:var(--mustard);color:var(--mustard);background:var(--mustard-bg)}

/* PRIORITY */
.priority-legend{display:flex;gap:12px;margin-bottom:13px;align-items:center;flex-wrap:wrap}
.pleg{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--text-muted)}
.pleg-dot{width:10px;height:10px;border-radius:2px;flex-shrink:0}
.edit-hint{font-size:10px;color:var(--mustard);font-weight:700;margin-left:auto;background:var(--mustard-bg);padding:4px 10px;border-radius:20px}

/* PDCA */
.pdca-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:11px;margin-bottom:22px}
.pdca-col{border-radius:11px;overflow:hidden;border:.5px solid var(--border);box-shadow:0 1px 4px rgba(0,0,0,.05)}
.pdca-header{padding:11px 13px;display:flex;align-items:center;gap:9px}
.pdca-icon{width:29px;height:29px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:800;flex-shrink:0}
.pdca-ht span{font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.6px;display:block}
.pdca-ht small{font-size:10px;display:block;font-weight:400;opacity:.7;margin-top:1px}
.plan-col .pdca-header{background:#EEF2FF}.plan-col .pdca-icon{background:#C7D2FE;color:#3730A3}.plan-col .pdca-ht span{color:#3730A3}
.do-col .pdca-header{background:#FEF3C7}.do-col .pdca-icon{background:#FDE68A;color:#92400E}.do-col .pdca-ht span{color:#92400E}
.check-col .pdca-header{background:#D1FAE5}.check-col .pdca-icon{background:#6EE7B7;color:#065F46}.check-col .pdca-ht span{color:#065F46}
.act-col .pdca-header{background:#FEE2E2}.act-col .pdca-icon{background:#FECACA;color:#991B1B}.act-col .pdca-ht span{color:#991B1B}
.pdca-body{background:var(--white);padding:9px;min-height:180px}

/* TASK */
.task-card{background:var(--gray-bg);border-radius:8px;padding:9px 11px;margin-bottom:7px;border-left:3px solid transparent;position:relative;transition:box-shadow .15s}
.task-card:hover{box-shadow:0 2px 8px rgba(0,0,0,.09)}
.task-card.priority-high{border-left-color:#EF4444}
.task-card.priority-mid{border-left-color:var(--mustard)}
.task-card.priority-low{border-left-color:#10B981}
.task-card.done-card{border-left-color:#10B981;opacity:.65;background:#F0FDF4}
.task-title{font-size:12px;font-weight:600;color:var(--text-dark);line-height:1.45;margin-bottom:5px;outline:none;min-width:1px}
.task-title:focus{background:rgba(200,146,42,.1);border-radius:3px;padding:2px 4px;margin:-2px -4px}
.done-card .task-title{text-decoration:line-through;color:var(--text-muted)}
.task-meta{display:flex;align-items:center;justify-content:space-between;margin-top:4px;gap:4px}
.task-date,.task-owner{font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px;cursor:pointer;outline:none;font-family:inherit;border:none;min-width:20px}
.task-date{color:var(--text-muted);background:var(--gray-light)}
.task-date:focus{background:var(--mustard-bg);color:#92400E}
.task-owner{color:var(--navy-l);background:#EFF6FF}
.task-owner:focus{background:#DBEAFE}
.task-actions{position:absolute;top:6px;right:6px;display:none;gap:3px}
.task-card:hover .task-actions{display:flex}
.task-btn{width:22px;height:22px;border:none;border-radius:5px;cursor:pointer;font-size:12px;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.07);color:var(--text-muted);font-family:inherit}
.task-btn:hover{background:rgba(0,0,0,.15)}
.add-task-btn{width:100%;padding:8px;border:1.5px dashed var(--gray-light);background:none;border-radius:8px;font-size:11px;color:var(--text-muted);cursor:pointer;text-align:center;margin-top:3px;font-family:inherit;transition:all .15s}
.add-task-btn:hover{border-color:var(--mustard);color:var(--mustard);background:var(--mustard-bg)}

/* ROADMAP */
.roadmap-section{margin-bottom:24px}
.section-label{font-size:12px;font-weight:800;color:var(--navy);text-transform:uppercase;letter-spacing:.6px;margin-bottom:11px;padding-bottom:7px;border-bottom:2px solid var(--mustard);display:inline-block}
.roadmap-lanes{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));border:.5px solid var(--border);border-radius:11px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.05)}
.roadmap-week{background:var(--white);border-right:.5px solid var(--border)}
.roadmap-week:last-child{border-right:none}
.rw-header{background:var(--navy);padding:9px 12px;text-align:center}
.rw-wl{color:rgba(255,255,255,.55);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;outline:none;min-width:1px}
.rw-dr{color:var(--mustard-l);font-size:11px;font-weight:700;margin-top:2px;outline:none;min-width:1px}
.rw-body{padding:8px;min-height:90px}
.rm-pill{border-radius:5px;padding:5px 9px;margin-bottom:5px;font-size:10px;font-weight:700;cursor:text;outline:none;min-width:1px;line-height:1.35;display:block;font-family:inherit;border:none;text-align:left;width:100%}
.rm-pill:focus{outline:2px solid var(--mustard);outline-offset:1px}
.rm-pill.navy{background:#EFF3FA;color:#0D2140;border-left:2.5px solid var(--navy)}
.rm-pill.mustard{background:var(--mustard-bg);color:#92400E;border-left:2.5px solid var(--mustard)}
.rm-pill.green{background:#D1FAE5;color:#065F46;border-left:2.5px solid #10B981}
.rm-pill.red{background:#FEE2E2;color:#991B1B;border-left:2.5px solid #EF4444}
.rm-pill.done-pill{background:#F0FDF4;color:#6B7280;border-left:2.5px solid #10B981;text-decoration:line-through;opacity:.6}
.add-rm-btn{width:100%;padding:6px;border:1.5px dashed rgba(0,0,0,.12);background:none;border-radius:5px;font-size:10px;color:var(--text-muted);cursor:pointer;text-align:center;font-family:inherit;margin-top:3px}
.add-rm-btn:hover{border-color:var(--mustard);color:var(--mustard);background:var(--mustard-bg)}

/* PENDENCIAS */
.pa-section{margin-bottom:26px}
.pa-header-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.pa-add-btn{padding:8px 18px;background:var(--navy);color:#fff;border:none;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit}
.pa-add-btn:hover{background:var(--navy-l)}
.pa-cols{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.pa-col{background:var(--white);border:.5px solid var(--border);border-radius:11px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.05)}
.pa-col-header{padding:12px 16px;display:flex;align-items:center;justify-content:space-between}
.pa-col-header.pending{background:#FEF3C7}
.pa-col-header.done{background:#D1FAE5}
.pa-col-title{font-size:13px;font-weight:800;display:flex;align-items:center;gap:8px}
.pa-col-header.pending .pa-col-title{color:#92400E}
.pa-col-header.done .pa-col-title{color:#065F46}
.pa-col-icon{width:24px;height:24px;border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:13px}
.pa-col-header.pending .pa-col-icon{background:#FDE68A}
.pa-col-header.done .pa-col-icon{background:#6EE7B7}
.pa-count{font-size:11px;font-weight:800;padding:3px 10px;border-radius:10px}
.pa-col-header.pending .pa-count{background:#FDE68A;color:#92400E}
.pa-col-header.done .pa-count{background:#6EE7B7;color:#065F46}
.pa-body{padding:10px;min-height:100px}
.pa-empty{font-size:12px;color:var(--text-muted);text-align:center;padding:24px 0;opacity:.6}
.pa-row{background:var(--gray-bg);border-radius:9px;padding:11px 13px;margin-bottom:9px;border-left:3px solid var(--mustard);position:relative}
.pa-row.done-row{border-left-color:#10B981;opacity:.78}
.pa-row:hover .pa-row-actions{display:flex}
.pa-row-actions{position:absolute;top:8px;right:8px;display:none;gap:3px}
.pa-row-desc{font-size:13px;font-weight:600;color:var(--text-dark);outline:none;min-width:1px;line-height:1.4;margin-bottom:8px;margin-right:54px}
.pa-row-desc:focus{background:rgba(200,146,42,.1);border-radius:3px;padding:2px 4px;margin-left:-4px}
.pa-row-meta{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}
.pa-meta-field{display:flex;flex-direction:column;gap:3px}
.pa-meta-label{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted)}
.pa-meta-val{font-size:12px;font-weight:600;color:var(--text-dark);outline:none;border:none;background:var(--gray-light);border-radius:5px;padding:4px 8px;font-family:inherit;cursor:text;min-width:10px}
.pa-meta-val:focus{background:var(--mustard-bg);color:#92400E;outline:none}
.pa-status-sel{font-size:11px;font-weight:700;border:none;border-radius:5px;padding:4px 8px;font-family:inherit;cursor:pointer;appearance:none;-webkit-appearance:none;background:var(--gray-light);color:var(--text-muted)}
.pa-status-sel.s-pending{background:#FEF3C7;color:#92400E}
.pa-status-sel.s-done{background:#D1FAE5;color:#065F46}

/* FERRAZ CARD */
.ferraz-section{background:var(--white);border-radius:12px;border:.5px solid var(--border);overflow:hidden;margin-bottom:24px;box-shadow:0 2px 8px rgba(124,58,237,.1)}
.ferraz-header{background:linear-gradient(135deg,#4C1D95,#7C3AED);padding:16px 20px;display:flex;align-items:center;justify-content:space-between}
.ferraz-header h3{color:#fff;font-size:15px;font-weight:700}
.ferraz-header span{color:rgba(255,255,255,.7);font-size:11px}
.ferraz-body{padding:14px}
.ferraz-cols{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.ferraz-col-title{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px;padding-bottom:6px;border-bottom:2px solid;}
.ferraz-pending-title{color:#7C3AED;border-bottom-color:#7C3AED}
.ferraz-done-title{color:#10B981;border-bottom-color:#10B981}
.f-task{background:var(--gray-bg);border-radius:8px;padding:9px 12px;margin-bottom:7px;border-left:3px solid #7C3AED;position:relative}
.f-task.f-done{border-left-color:#10B981;opacity:.7;background:#F0FDF4}
.f-task:hover .task-actions{display:flex}
.f-task-title{font-size:12px;font-weight:600;color:var(--text-dark);line-height:1.4;margin-bottom:5px;outline:none;min-width:1px}
.f-task-title:focus{background:rgba(124,58,237,.1);border-radius:3px}
.f-done .f-task-title{text-decoration:line-through;color:var(--text-muted)}
.f-task-meta{display:flex;gap:5px;align-items:center;flex-wrap:wrap}
.f-badge{font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px;border:none;font-family:inherit;cursor:text;outline:none;min-width:10px}
.f-date{background:var(--gray-light);color:var(--text-muted)}
.f-date:focus{background:var(--mustard-bg);color:#92400E}
.f-pri{background:#EDE9FE;color:#7C3AED}
.f-done-badge{background:#D1FAE5;color:#065F46}
.add-f-btn{width:100%;padding:7px;border:1.5px dashed rgba(124,58,237,.3);background:none;border-radius:7px;font-size:11px;color:#7C3AED;cursor:pointer;text-align:center;font-family:inherit;margin-top:4px}
.add-f-btn:hover{border-color:#7C3AED;background:#F5F3FF}

@media(max-width:1000px){.pdca-grid{grid-template-columns:1fr 1fr}.roadmap-lanes{grid-template-columns:1fr 1fr}.ferraz-cols{grid-template-columns:1fr}}
@media(max-width:650px){.pdca-grid{grid-template-columns:1fr}.roadmap-lanes{grid-template-columns:1fr}.pa-cols{grid-template-columns:1fr}.pa-row-meta{grid-template-columns:1fr 1fr}.main{padding:12px}}
@media print{.top-bar{position:relative}.tabs,.export-bar{display:none}.bu-section{display:block!important;page-break-inside:avoid}.bu-section+.bu-section{page-break-before:always}body{background:#fff}}
</style>
</head>
<body>

<div class="top-bar">
  <div>
    <h1 contenteditable="true">Dashboard de Pendências — Liderança de Marketing</h1>
    <p contenteditable="true">Reunião Semanal · Ciclo PDCA · Atualizado 22/04/2026</p>
  </div>
  <div class="top-bar-right">
    <span class="badge" contenteditable="true">Semana 22–28/04/2026</span>
  </div>
</div>

<div class="main">
  <div class="export-bar">
    <button class="btn-exp primary" onclick="window.print()">🖨 Imprimir / PDF</button>
    <button class="btn-exp" onclick="saveHTML()">💾 Salvar .html</button>
    <button class="btn-exp" onclick="if(confirm('Restaurar estado original?'))location.reload()">↩ Restaurar</button>
    <span id="save-status">Edições não salvas</span>
  </div>

  <div class="tabs">
    <button class="tab-btn active" onclick="showBU('med',this)">🩺 Pós Medicina</button>
    <button class="tab-btn" onclick="showBU('odonto',this)">🦷 Pós Odonto</button>
    <button class="tab-btn" onclick="showBU('grad',this)">🎓 Graduação</button>
    <button class="tab-btn" onclick="showBU('cross',this)">🔗 Cross-BU</button>
    <button class="tab-btn ferraz-tab" onclick="showBU('ferraz',this)">⚡ Ferraz — To Do</button>
  </div>

  <!-- ══════════════ PÓS MEDICINA ══════════════ -->
  <div class="bu-section visible" id="bu-med">
    <div class="section-header">
      <h2 contenteditable="true">Pós Medicina — Unidade de Negócio 2</h2>
      <span class="sec-sub" contenteditable="true">@Squad · @Comunicação · @CX · @Martech</span>
    </div>

    <div class="kpi-bar" id="kpi-med">
      <div class="kpi-card ok"><div class="kpi-label" contenteditable="true">Receita YTD vs Meta</div><div class="kpi-value" contenteditable="true">+14%</div><div class="kpi-sub" contenteditable="true">R$17,8M esperado fech. abr · Meta R$15,5M</div></div>
      <div class="kpi-card ok"><div class="kpi-label" contenteditable="true">CAC Abril</div><div class="kpi-value" contenteditable="true">R$3.9K</div><div class="kpi-sub" contenteditable="true">Recuperado — orçado R$4,3K ✅</div></div>
      <div class="kpi-card ok"><div class="kpi-label" contenteditable="true">Vendas Abril</div><div class="kpi-value" contenteditable="true">106%</div><div class="kpi-sub" contenteditable="true">70 pagos · Meta 66 ✅</div></div>
      <div class="kpi-card warn"><div class="kpi-label" contenteditable="true">Matrículas vs Meta</div><div class="kpi-value" contenteditable="true">−29%</div><div class="kpi-sub" contenteditable="true">Atraso assinaturas de contrato</div></div>
      <div class="kpi-card ok"><div class="kpi-label" contenteditable="true">Projeção Anual</div><div class="kpi-value" contenteditable="true">R$65M</div><div class="kpi-sub" contenteditable="true">R$6–7M acima do orçamento</div></div>
    </div>
    <div class="kpi-actions-bar"><button class="kpi-add-btn" onclick="addKPI('kpi-med')">+ Novo indicador</button></div>

    <div class="priority-legend">
      <span style="font-size:11px;font-weight:700;color:var(--text-muted)">Prioridade:</span>
      <span class="pleg"><span class="pleg-dot" style="background:#EF4444"></span>Alta</span>
      <span class="pleg"><span class="pleg-dot" style="background:var(--mustard)"></span>Média</span>
      <span class="pleg"><span class="pleg-dot" style="background:#10B981"></span>Normal</span>
      <span class="edit-hint">✎ Clique em qualquer texto para editar</span>
    </div>

    <div class="pdca-grid">
      <div class="pdca-col plan-col"><div class="pdca-header"><div class="pdca-icon">P</div><div class="pdca-ht"><span>Plan</span><small>Planejar</small></div></div><div class="pdca-body" id="med-plan">
